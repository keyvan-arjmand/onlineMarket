@using Domain.Entities.Products
@{
    List<Category> categories = ViewBag.cats;
}
<div class="container-xxl flex-grow-1 container-p-y">
    <div class="card">
        <div class="d-flex justify-content-between">
            <div class=" w-100">
                <form asp-action="Category" asp-controller="Admin" class="input-group  w-25" style="height: 40px;
                 margin: 18px 26px 0px 0px;direction: ltr">
                    <input type="text" class="form-control" name="search" placeholder=""
                           aria-label="Example text with button addon"
                           aria-describedby="button-addon1">
                    <button class="btn btn-outline-primary" type="submit" id="button-addon1">جستجو</button>

                </form>
            </div>
            <div>
                <button type="button" class="btn btn-success"
                        data-bs-toggle="modal"
                        data-bs-target="#InsertModal">افزودن
                </button>
            </div>
        </div>
        <div class="table-responsive text-nowrap">
            <table class="table">
                <thead>
                <tr>
                    <th>نام</th>
                    <th>عملیات</th>
                </tr>
                </thead>
                <tbody class="table-border-bottom-0">
                @foreach (var i in categories)
                {
                    <tr onclick="openEditModal(@i.Id, '@i.Title')">

                        <td>
                            <i class="fab fa-angular fa-lg text-danger me-3"></i> <strong>@i.Title</strong>
                        </td>

                        <td>
                            <div class="dropdown">
                                <button type="button" class="btn p-0 dropdown-toggle hide-arrow"
                                        data-bs-toggle="dropdown">
                                    <i class="bx bx-dots-vertical-rounded"></i>
                                </button>
                                <div class="dropdown-menu">
                                    <a class="dropdown-item" href="javascript:void(0);" data-bs-toggle="modal"
                                       data-bs-target="#UpdateModal">
                                        <i
                                            class="bx bx-edit-alt me-1"></i> ویرایش</a>
                                    <a class="dropdown-item" href="javascript:void(0);"><i class="bx bx-trash me-1"></i>
                                        حذف</a>
                                </div>
                            </div>
                        </td>
                    </tr>
                }

                </tbody>
            </table>
        </div>
    </div>
    <div class="modal fade" id="InsertModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">

            <form class="mb-3" method="POST" asp-action="InsertCat" asp-controller="Admin"
                  enctype="multipart/form-data">

                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title">افزودن دسته بندی</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">

                        <!-- Name -->
                        <div class="mb-3">
                            <label class="form-label">نام </label>
                            <input type="text" id="name1" name="Title" class="form-control"/>
                        </div>


                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">بستن</button>
                        <button type="submit" class="btn btn-primary">ذخیره</button>
                    </div>

                </div>

            </form>

        </div>
    </div>

    <div class="modal fade" id="UpdateModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">

            <form class="mb-3"
                  method="POST"
                  asp-action="UpdateCat"
                  asp-controller="Admin"
                  enctype="multipart/form-data">

                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title">ویرایش دسته بندی</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">

                        <!-- ID -->
                        <input type="hidden" id="Id" name="Id"/>

                        <!-- Name -->
                        <div class="mb-3">
                            <label class="form-label">نام محصول</label>
                            <input type="text" id="name" name="Title" class="form-control"/>
                        </div>


                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">بستن</button>
                        <button type="submit" class="btn btn-primary">ذخیره</button>
                    </div>

                </div>

            </form>

        </div>
    </div>
</div>
<script>
    function openEditModal(id, name) {

        document.getElementById("Id").value = id;
        document.getElementById("name").value = name;


        @*    var modal = new bootstrap.Modal(document.getElementById('UpdateModal')); *@
        @*     modal.show();` *@
    }
</script>