@using Domain.Entities.Orders
@using Domain.Entities.Regions
@{
    List<Discount> discounts = ViewBag.Discount;
}
<div class="container-xxl flex-grow-1 container-p-y">
    <div class="card">
        <div class="d-flex justify-content-between">
            <div class="w-100 ">
                <form asp-action="Discounts" asp-controller="Admin" class="input-group  w-25" style="height: 40px;
                 margin: 18px 26px 0px 0px;direction: ltr">
                    <input type="text" class="form-control" name="search" placeholder=""
                           aria-label="Example text with button addon"
                           aria-describedby="button-addon1">
                    <button class="btn btn-outline-primary" type="submit" id="button-addon1">جستجو</button>

                </form>
            </div>
            <div>
                <button type="button" class="btn btn-success"
                        data-bs-toggle="modal"
                        data-bs-target="#InsertModal">افزودن
                </button>
            </div>
        </div>
        <div class="table-responsive text-nowrap">
            <table class="table">
                <thead>
                <tr>
                    <th>کد</th>
                    <th>مبلغ</th>
                    <th>عملیات</th>
                </tr>
                </thead>
                <tbody class="table-border-bottom-0">
                @{
                    foreach (var i in discounts)
                    {
                        <tr onclick="openEditModal(@i.Id, '@i.Code', @i.Amount )">

                            <td>
                                <strong>@i.Code</strong>
                            </td>

                            <td>
                                <strong>@i.Amount.ToString("N0")</strong>
                            </td>

                            <td>
                                <div class="dropdown">
                                    <button type="button" class="btn p-0 dropdown-toggle hide-arrow"
                                            data-bs-toggle="dropdown">
                                        <i class="bx bx-dots-vertical-rounded"></i>
                                    </button>

                                    <div class="dropdown-menu">
                                        <a class="dropdown-item"
                                           href="javascript:void(0);"
                                           data-bs-toggle="modal"
                                           data-bs-target="#UpdateModal">
                                            <i class="bx bx-edit-alt me-1"></i>
                                            ویرایش
                                        </a>

                                        <form method="post"
                                              asp-page-handler="DeleteCat">
                                            <input type="hidden" name="id" value="@i.Id"/>

                                            <button type="submit" class="dropdown-item">
                                                <i class="bx bx-trash me-1"></i>
                                                حذف
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
    <div class="modal fade" id="InsertModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">

            <form method="post"
                  asp-action="InsertDiscount">

                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title">افزودن کد تخفیف</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">

                        <div class="mb-3">
                            <label class="form-label">کد</label>
                            <input type="text"
                                   name="code"
                                   class="form-control"/>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">مبلغ</label>
                            <input type="text"
                                   name="amount"
                                   class="form-control"/>
                        </div>

                     
                    </div>

                    <div class="modal-footer">
                        <button type="button"
                                class="btn btn-secondary"
                                data-bs-dismiss="modal">
                            بستن
                        </button>

                        <button type="submit"
                                class="btn btn-primary">
                            ذخیره
                        </button>
                    </div>

                </div>

            </form>

        </div>
    </div>

    <div class="modal fade" id="UpdateModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">

            <form method="post"
                  asp-action="UpdateDiscount">

                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title">ویرایش کد تخفیف</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">

                        <input type="hidden"
                               id="Id"
                               name="id"/>

                        <div class="mb-3">
                            <label class="form-label">کد</label>
                            <input type="text"
                                   name="code"
                                   id="code"
                                   class="form-control"/>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">مبلغ</label>
                            <input type="text"
                                   name="amount"
                                   id="amount"
                                   class="form-control"/>
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button type="button"
                                class="btn btn-secondary"
                                data-bs-dismiss="modal">
                            بستن
                        </button>

                        <button type="submit"
                                class="btn btn-primary">
                            ذخیره
                        </button>
                    </div>

                </div>

            </form>

        </div>
    </div>
</div>
<script>
    function openEditModal(id, title, parentId) {

        document.getElementById("Id").value = id;
        document.getElementById("code").value = title;
        document.getElementById("amount").value = parentId;
    }
</script>