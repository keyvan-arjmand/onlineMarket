@using Application.Common.Utilities
@using Domain.Entities.Orders
@using Domain.Enums
@{
    Order ord = ViewBag.orderInfo;
}
<div class="container-xxl flex-grow-1 container-p-y">
    <form asp-action="StatusOrder" asp-controller="Admin" class="card">
        <h5 class="card-header">سفارشات</h5>

        <div class="card-body demo-vertical-spacing demo-only-element">
            <div class="d-flex justify-content-between align-items-center gap-2">
                <div class="w-100">
                    <label for="defaultFormControlInput" class="form-label">نام</label>
                    <input
                        type="text"
                        class="form-control"
                        id="defaultFormControlInput"
                        value="@ord.FullName" readonly="readonly"
                        aria-describedby="defaultFormControlHelp"/>
                </div>
                <div class="w-100">
                    <label for="defaultFormControlInput" class="form-label">کد سفارش</label>
                    <input
                        type="text"
                        class="form-control"
                        id="defaultFormControlInput"
                        value="@ord.TrackingCode" readonly="readonly"
                        aria-describedby="defaultFormControlHelp"/>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center gap-2">
                <div class="w-100">
                    <label for="defaultFormControlInput" class="form-label">آدرس</label>
                    <input
                        type="text"
                        class="form-control"
                        id="defaultFormControlInput"
                        value="@ord.Address" readonly="readonly"
                        aria-describedby="defaultFormControlHelp"/>
                </div>
                <div class="w-100">
                    <label for="defaultFormControlInput" class="form-label">شماره</label>
                    <input
                        type="text"
                        class="form-control"
                        id="defaultFormControlInput"
                        value="@ord.PhoneNumber" readonly="readonly"
                        aria-describedby="defaultFormControlHelp"/>
                </div>
            </div>
            <div class="d-flex justify-content-between align-items-center gap-2">
                <div class="w-100">
                    <label for="defaultFormControlInput" class="form-label">جمع سفارش</label>
                    <input
                        type="text"
                        class="form-control"
                        id="defaultFormControlInput"
                        value="@ord.FinalPrice" readonly="readonly"
                        aria-describedby="defaultFormControlHelp"/>
                </div>
                <input hidden="hidden" name="id" value="@ord.Id"/>
                <div class="mb-3 w-100">
                    <label for="defaultSelect" class="form-label">وضعیت سفارش</label>
                    <select name="status" class="form-select">
                        @foreach (OrderStatus status in Enum.GetValues(typeof(OrderStatus)))
                        {
                            if (status == ord.OrderStatus)
                            {
                                <option selected="selected" value="@((int) status)">@status.ToDescription()</option>
                            }
                            else
                            {
                                <option value="@((int) status)">@status.ToDescription()</option>
                            }
                        }
                    </select>
                </div>
            </div>

            <button type="submit" class="btn rounded-pill btn-success">ویرایش</button>
        </div>


        <div class="table-responsive text-nowrap">
            <table class="table">
                <thead>
                <tr>
                    <th class="text-center">نام</th>
                    <th class="text-center">کد محصول</th>
                    <th class="text-center">عکس</th>
                    <th class="text-center">تعداد</th>
                    <th class="text-center">دسته بندی</th>
                </tr>
                </thead>
                <tbody class="table-border-bottom-0">
                @foreach (var i in ord.OrderItems.ToList())
                {
                    <tr>

                        <td class="text-center">
                            <i class="fab fa-angular fa-lg text-danger me-3"></i> <strong>@i.Product.Name</strong>
                        </td>
                        <td  class="text-center">@i.Product.Code</td>
                        <td class="text-center">
                            <ul class="list-unstyled users-list m-0 avatar-group d-flex align-items-center justify-content-center">
                                <li data-bs-toggle="tooltip" data-popup="tooltip-custom" data-bs-placement="top"
                                    class="avatar avatar-xs pull-up" title=""
                                    data-bs-original-title="@i.Product.Name">
                                    <img src="~/image/prods/@i.Product.ImageUrl" alt="Avatar"
                                         class="rounded-circle">
                                </li>
                            </ul>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-label-primary me-1">@i.Count</span>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-label-primary me-1">@i.Product.Category.Title</span>
                        </td>
                    </tr>
                }

                </tbody>
            </table>
        </div>

    </form>
</div>
     