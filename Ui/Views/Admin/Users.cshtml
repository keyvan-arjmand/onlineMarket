@using Domain.Entities.Identities
@{
    List<User> user = ViewBag.Users;
}
<div class="container-xxl flex-grow-1 container-p-y">
    <div class="card" style="min-height: 300PX">
        <div class="d-flex justify-content-between">
            <form asp-action="Users" asp-controller="Admin" class="input-group  w-25" style="height: 40px;
                 margin: 18px 26px 0px 0px;direction: ltr">
                <input type="text" class="form-control" name="search" placeholder=""
                       aria-label="Example text with button addon"
                       aria-describedby="button-addon1">
                <button class="btn btn-outline-primary" type="submit" id="button-addon1">جستجو</button>

            </form>
            <h5 class="card-header">کاربران</h5>

        </div>
        <div class="table-responsive text-nowrap" style="min-height: 150px">
            <table class="table">
                <thead>
                <tr>
                    <th>شماره</th>
                    <th>نام</th>
                    <th>ایمیل</th>
                    <th>نام کاربری</th>
                    <th>عملیات</th>
                </tr>
                </thead>
                <tbody class="table-border-bottom-0">
                @foreach (var i in user)
                {
                    <tr onclick="openEditModal(@i.Id, '@i.UserName', '@i.Email')">
                        <td>@i.Id</td>
                        <td>
                            <i class="fab fa-angular fa-lg text-danger me-3"></i> <strong>@i.UserName</strong>
                        </td>
                        <td>@i.Email</td>
                        <td>@i.UserName</td>
                        <td>
                            <div class="dropdown">
                                <button type="button" class="btn p-0 dropdown-toggle hide-arrow"
                                        data-bs-toggle="dropdown">
                                    <i class="bx bx-dots-vertical-rounded"></i>
                                </button>
                                <div class="dropdown-menu">
                                    <a class="dropdown-item" href="javascript:void(0);"
                                       data-bs-toggle="modal"
                                       data-bs-target="#basicModal">
                                        <i
                                            class="bx bx-edit-alt me-1"></i> ویرایش</a>
                                    <a class="dropdown-item" href="javascript:void(0);"><i class="bx bx-trash me-1"></i>
                                        حذف</a>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
    <div class="modal fade" id="basicModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">

            <form class="mb-3" method="POST" asp-action="UpdateUser" asp-controller="Admin">

                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title">ویرایش کاربر</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">

                        <!-- ID -->
                        <input type="hidden" id="userId" name="Id"/>

                        <div class="mb-3">
                            <label class="form-label">نام</label>
                            <input type="text" id="nameBasic" name="Name" class="form-control"/>
                            <input type="text" id="id" name="Id" hidden="hidden"/>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">ایمیل</label>
                            <input type="text" id="emailBasic" name="Email" class="form-control"/>
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">بستن</button>
                        <button type="submit" class="btn btn-primary">ذخیره</button>
                    </div>

                </div>

            </form>

        </div>
    </div>
</div>

<script>
    function openEditModal(id, name, email) {

        // set values
        document.getElementById("userId").value = id;
        document.getElementById("nameBasic").value = name;
        document.getElementById("emailBasic").value = email;

        // open bootstrap modal
        @* var modal = new bootstrap.Modal(document.getElementById('basicModal')); *@
        @* modal.show(); *@
    }
</script>