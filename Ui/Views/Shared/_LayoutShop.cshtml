                                <div class="header-cart-interest">
                                    <a href="@Url.Action("Favorite", "User")" class="d-block">
                                        <i class="fa fa-heart"></i>
                                        <span class="counter">@favCount</span>
                                    </a>
                                </div>
                            }
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
        <!--    responsive-megamenu-mobile----------------->
        <nav class="sidebar">
            <div class="nav-header">
                <div class="header-cover"></div>
                <div class="logo-wrap">
                    <a class="logo-icon" href="#"><img alt="logo-icon" src="~/Shop/assets/images/logo.png"
                                                       width="40"></a>
                </div>
            </div>
            <ul class="nav-categories ul-base">
                @foreach (var i in cats)
