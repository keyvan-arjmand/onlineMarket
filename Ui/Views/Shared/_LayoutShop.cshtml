                                                                            </div>
                                                                            <div class="quantity">
                                                                    <span class="quantity-Price-amount">
                                                                        @i.Price.ToString("N0")
                                                                        <span>تومان</span>
                                                                    </span>
                                                                            </div>
                                                                        </div>
                                                                    </li>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                <span>سبد خالی</span>
                                                            }
                                                        }


                                                    </ul>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="mini-card-total">
                                            <strong>قیمت کل : </strong>
                                            <span class="price-total"> @basket.SumPrice.ToString("N0")
                                                <span>تومان</span>
                                                </span>
                                        </div>
                                        <div class="mini-card-button">
                                            <a href="@Url.Action("Basket", "Basket")" class="view-card">مشاهده سبد
                                                خرید</a>
                                            <a href="@Url.Action("Basket", "Basket")" class="card-checkout">تسویه
                                                حساب</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            @if (User.Identity.IsAuthenticated)
