@using System.Security.Claims
@using Application.Common.Utilities
@using Application.Interfaces
@using Domain.Entities.Products
@using Microsoft.EntityFrameworkCore
@using Ui.Models
@inject IUnitOfWork UnitOfWork
@inject IHttpContextAccessor HttpContextAccessor
@{
    var cats = await UnitOfWork
        .GenericRepository<Category>()
        .TableNoTracking
        .ToListAsync();
    var basket = HttpContextAccessor.HttpContext?
        .Session
        .GetObject<Basket>("basket") ?? new Basket();

    basket.SumPrice = basket.BasketItems.Sum(x => x.Price * x.Count);
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier).ToInt();
    int favCount = await UnitOfWork.GenericRepository<ProductFav>().TableNoTracking.CountAsync(x => x.UserId == userId);
}
<!DOCTYPE html>
<html lang="fa" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>فروشگاه اینترنتی کالا مارکت</title>
