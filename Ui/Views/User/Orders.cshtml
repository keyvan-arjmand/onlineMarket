@using Application.Common.Utilities
@using Domain.Entities.Orders
@{
    Domain.Entities.Identities.User user = ViewBag.CurrentUser;
    List<Order> ords = ViewBag.Orders;
    Layout = "_LayoutShop";
}

<div class="container-main">
    <div class="d-block">
        <section class="profile-home">
            <div class="col-lg">
                <div class="post-item-profile order-1 d-block">
                    <div class="col-lg-3 col-md-3 col-xs-12 pr">
                        <div class="sidebar-profile sidebar-navigation">
                            <section class="profile-box">
                                <header class="profile-box-header-inline">
                                    <div class="profile-avatar user-avatar profile-img">
                                        <img src="~/Shop/assets/images/man.png">
                                    </div>
                                </header>
                                <footer class="profile-box-content-footer">
                                    <span class="profile-box-nameuser">@user.Name @user.Family</span>
                                    <span class="profile-box-registery-date">عضویت در سایت 2 پیش</span>
                                    <span class="profile-box-phone">شماره همراه : *******0991</span>
                                    <div class="profile-box-tabs">
                                        <a href="#" class="profile-box-tab-sign-out"><i
                                                class="mdi mdi-logout-variant"></i>خروج از حساب</a>
                                    </div>
                                </footer>
                            </section>
                            <section class="profile-box">
                                <ul class="profile-account-navs">
                                    <li class="profile-account-nav-item navigation-link-dashboard">
                                        <a href="@Url.Action("Profile")" class=""><i
                                                class="mdi mdi-account-outline"></i>
                                            پروفایل
                                        </a>
                                    </li>
                                    <li class="profile-account-nav-item navigation-link-dashboard">
                                        <a href="@Url.Action("Orders")" class="active"><i class="mdi mdi-cart"></i>
                                            همه سفارش ها
                                        </a>
                                    </li>
                                    <li class="profile-account-nav-item navigation-link-dashboard">
                                        <a href="@Url.Action("Favorite")"  class=""><i class="mdi mdi-heart"></i>
                                            لیست علاقه مندی
                                        </a>
                                    </li>
                                    <li class="profile-account-nav-item navigation-link-dashboard">
                                        <a href="@Url.Action("Information")" class=""><i
                                                class="mdi mdi-tooltip-text-outline"></i>
                                            اطلاعات حساب
                                        </a>
                                    </li>
                                </ul>
                            </section>
                        </div>
                    </div>
                    <div class="col-lg-9 col-md-9 col-xs-12 pl">
                        <div class="profile-content">
                            <div class="profile-stats">
                                <div class="table-orders">
                                    <table class="table table-profile-orders">
                                        <thead class="thead-light">
                                        <tr>
                                            <th scope="col">شماره سفارش</th>
                                            <th scope="col">تاریخ ثبت سفارش</th>
                                            <th scope="col">وضعیت</th>
                                            <th scope="col">مجموع</th>
                                            <th scope="col">جزئیات</th>
                                        </tr>
                                        </thead>
                                        <tbody>
                                        @foreach (var i in ords)
                                        {
                                            <tr>
                                                <td class="order-code">@i.TrackingCode</td>
                                                <td>سه شنبه 4 فروردین 99</td>
                                                <td class="Waiting text-success">@i.OrderStatus.ToDescription()</td>
                                                <td class="totla">
                                                    <span class="amount">@i.FinalPrice.ToString("N0")
                                                        <span>تومان</span>
                                                    </span>
                                                </td>
                                                <td class="detail">
                                                    <a href="@Url.Action("OrderDetail", "User", new {id = i.Id})"
                                                       class="btn btn-secondary d-block">نمایش</a></td>
                                            </tr>
                                        }

                                        </tbody>
                                    </table>
                                    <div class="profile-orders">
                                        <div class="collapse">
                                            <div class="profile-orders-item">
                                                @foreach (var i in ords)
                                                {
                                                    <div class="profile-orders-header">
                                                        <a href=""
                                                           class="profile-orders-header-details">
                                                            <div class="profile-orders-header-summary">
                                                                <div class="profile-orders-header-row">
                                                                <span
                                                                    class="profile-orders-header-id">@i.TrackingCode</span>
                                                                    <span
                                                                        class="profile-orders-header-state text-success">@i.OrderStatus.ToDescription()</span>
                                                                </div>
                                                            </div>
                                                        </a>
                                                        <!-- <hr class="ui-separator"> -->
                                                        <div class="profile-orders-header-data">
                                                            <div class="profile-info-row">
                                                                <div class="profile-info-label">تاریخ ثبت سفارش</div>
                                                                <div class="profile-info-value">سه شنبه 4 فروردین 1405
                                                                </div>
                                                            </div>
                                                            <div class="profile-info-row">
                                                                <div class="profile-info-label">مبلغ قابل پرداخت</div>
                                                                <div class="profile-info-value">0</div>
                                                            </div>
                                                            <div class="profile-info-row">
                                                                <div class="profile-info-label">مبلغ کل</div>
                                                                <div class="profile-info-value">
                                                                <span class="amount">@i.FinalPrice.ToString("N0")
                                                                    <span>تومان</span>
                                                                </span>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>