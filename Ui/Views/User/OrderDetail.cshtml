@using Domain.Entities.Orders
@{
    Domain.Entities.Identities.User user = ViewBag.CurrentUser;
    Order ord = ViewBag.Order;
    Layout = "_LayoutShop";
}

<div class="container-main">
    <div class="d-block">
        <section class="profile-home">
            <div class="col-lg">
                <div class="post-item-profile order-1 d-block">
                    <div class="col-lg-3 col-md-3 col-xs-12 pr">
                        <div class="sidebar-profile sidebar-navigation">
                            <section class="profile-box">
                                <header class="profile-box-header-inline">
                                    <div class="profile-avatar user-avatar profile-img">
                                        <img src="~/Shop/assets/images/man.png">
                                    </div>
                                </header>
                                <footer class="profile-box-content-footer">
                                    <span class="profile-box-nameuser">@user.Name @user.Family</span>
                                    <span class="profile-box-registery-date">عضویت در سایت 2 پیش</span>
                                    <span class="profile-box-phone">شماره همراه : *******0991</span>
                                    <div class="profile-box-tabs">
                                        <a href="#" class="profile-box-tab-sign-out"><i
                                                class="mdi mdi-logout-variant"></i>خروج از حساب</a>
                                    </div>
                                </footer>
                            </section>
                            <section class="profile-box">
                                <ul class="profile-account-navs">
                                    <li class="profile-account-nav-item navigation-link-dashboard">
                                        <a href="@Url.Action("Profile")" class=""><i
                                                class="mdi mdi-account-outline"></i>
                                            پروفایل
                                        </a>
                                    </li>
                                    <li class="profile-account-nav-item navigation-link-dashboard">
                                        <a href="@Url.Action("Orders")" class="active"><i class="mdi mdi-cart"></i>
                                            همه سفارش ها
                                        </a>
                                    </li>
                                    <li class="profile-account-nav-item navigation-link-dashboard">
                                        <a href="@Url.Action("Favorite")"  class=""><i class="mdi mdi-heart"></i>
                                            لیست علاقه مندی
                                        </a>
                                    </li>
                                    <li class="profile-account-nav-item navigation-link-dashboard">
                                        <a href="@Url.Action("Information")" class=""><i
                                                class="mdi mdi-tooltip-text-outline"></i>
                                            اطلاعات حساب
                                        </a>
                                    </li>
                                </ul>
                            </section>
                        </div>
                    </div>
                    <div class="col-lg-9 col-md-9 col-xs-12 pl">
                        <div class="profile-content">
                            <div class="profile-stats">
                                <div class="table-order-view">
                                    <h2 class="order-view-title mt-4 mb-3">جزییات سفارش </h2>
                                    <table class="table table-borderless">
                                        <thead>
                                        <tr>
                                            <th scope="col" class=" text-center">عکس محصول</th>
                                            <th scope="col" class=" text-center">نام محصول</th>
                                            <th scope="col" class=" text-center">تعداد</th>
                                            <th scope="col" class=" text-center">مجموع</th>
                                        </tr>
                                        </thead>
                                        <tbody>
                                        @foreach (var i in ord.OrderItems)
                                        {
                                            <tr>
                                                <td class="product-name text-center"><img
                                                        src="~/image/Prods/@i.Product.ImageUrl"
                                                        width="55"/>
                                                </td>
                                                <td class="product-name text-center">@i.Product.Name
                                                </td>
                                                <td class="product-name text-center">@i.Count
                                                </td>
                                                <td class="product-total text-center">
                                                    <span class="amount">
                                                        <span>تومان</span>
                                                        @i.Product.Price.ToString("N0")
                                                    </span>
                                                </td>
                                            </tr>
                                        }

                                        </tbody>
                                        <tfoot>
                                        <tr>
                                            <th scope="row">مجموع:</th>
                                            <td>
                                                        <span class="amount">
                                                            <span>تومان</span>
                                                            @ord.TotalPrice.ToString("N0")
                                                        </span>
                                            </td>
                                        </tr>
                                        <tr>
                                            <th scope="row">حمل و نقل:</th>
                                            <td>حمل و نقل رایگان</td>
                                        </tr>
                                        <tr>
                                            <th scope="row">روش پرداخت:</th>
                                            <td>انتقال مستقیم بانکی</td>
                                        </tr>
                                        <tr>
                                            <th scope="row">قیمت نهایی:</th>
                                            <td>
                                                        <span class="amount">
                                                            <span>تومان</span>
                                                            @ord.FinalPrice.ToString("N0")
                                                        </span>
                                            </td>
                                        </tr>
                                        </tfoot>
                                    </table>
                                    <br>
                                    <br>
                                    <div class="order-view-customer">
                                        <div class="box-header">
                                            <span class="box-title">نشانی ما</span>
                                        </div>
                                        <div class="profile-address-item">
                                            <div class="profile-address-content">
                                                <ul class="profile-address-info">
                                                    <li>
                                                        <div class="profile-address-info-item location">
                                                            <span class="title-address">آدرس : </span>
                                                            خراسان شمالی، بجنورد
                                                        </div>
                                                    </li>
                                                    <li>
                                                        <div class="profile-address-info-item location">
                                                            <span class="title-address">ایمیل : </span>
                                                            info@digismart.com
                                                        </div>
                                                    </li>
                                                    <li>
                                                        <div class="profile-address-info-item location">
                                                            <span class="title-address">شماره تلفن : </span>
                                                            0991*******
                                                        </div>
                                                    </li>
                                                    <li>
                                                        <div class="profile-address-info-item location">
                                                            <span class="title-address">کد پستی : </span>
                                                            945789651235
                                                        </div>
                                                    </li>
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>