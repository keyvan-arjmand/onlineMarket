@using Domain.Entities.Products
@{
    Domain.Entities.Identities.User user = ViewBag.CurrentUser;
    List<ProductFav> productFavs = ViewBag.favs;
    Layout = "_LayoutShop";
}

<div class="container-main">
    <div class="d-block">
        <section class="profile-home">
            <div class="col-lg">
                <div class="post-item-profile order-1 d-block">
                    <div class="col-lg-3 col-md-3 col-xs-12 pr">
                        <div class="sidebar-profile sidebar-navigation">
                            <section class="profile-box">
                                <header class="profile-box-header-inline">
                                    <div class="profile-avatar user-avatar profile-img">
                                        <img src="~/Shop/assets/images/man.png">
                                    </div>
                                </header>
                                <footer class="profile-box-content-footer">
                                    <span class="profile-box-nameuser">@user.Name @user.Family</span>
                                    <span class="profile-box-registery-date">عضویت در سایت 2 پیش</span>
                                    <span class="profile-box-phone">شماره همراه : *******0991</span>
                                    <div class="profile-box-tabs">
                                        <a href="#" class="profile-box-tab-sign-out"><i
                                                class="mdi mdi-logout-variant"></i>خروج از حساب</a>
                                    </div>
                                </footer>
                            </section>
                            <section class="profile-box">
                                <ul class="profile-account-navs">
                                    <li class="profile-account-nav-item navigation-link-dashboard">
                                        <a href="@Url.Action("Profile")" class=""><i
                                                class="mdi mdi-account-outline"></i>
                                            پروفایل
                                        </a>
                                    </li>
                                    <li class="profile-account-nav-item navigation-link-dashboard">
                                        <a href="@Url.Action("Orders")" class=""><i class="mdi mdi-cart"></i>
                                            سفارشات
                                        </a>
                                    </li>
                                    <li class="profile-account-nav-item navigation-link-dashboard">
                                        <a href="@Url.Action("Favorite")" class="active"><i class="mdi mdi-heart"></i>
                                            لیست علاقه مندی
                                        </a>
                                    </li>
                                    <li class="profile-account-nav-item navigation-link-dashboard">
                                        <a href="@Url.Action("Information")" class=""><i
                                                class="mdi mdi-tooltip-text-outline"></i>
                                            اطلاعات حساب
                                        </a>
                                    </li>
                                </ul>
                            </section>
                        </div>
                    </div>
                    <div class="col-lg-9 col-md-9 col-xs-12 pl">
                        <div class="profile-content">
                            <div class="profile-stats">
                                <div class="table-favorites">
                                    <table class="table ns-table table-profile-favorites">
                                        <thead>
                                        <tr>
                                            <th scope="col" width="50"></th>
                                            <th scope="col">نام محصول</th>
                                            <th scope="col">قیمت</th>
                                            <th class="actions-th"></th>
                                        </tr>
                                        </thead>
                                        <tbody>
                                        @{
                                            if (productFavs.Any())
                                            {
                                                foreach (var i in productFavs)
                                                {
                                                    <tr>
                                                        <th scope="row">
                                                            <div class="favorites-product-img">
                                                                <img
                                                                    src="~/image/Prods/@i.Product.ImageUrl">
                                                                <div class="product-rate">
                                                                    <i class="fa fa-star active"></i>
                                                                    <i class="fa fa-star active"></i>
                                                                    <i class="fa fa-star active"></i>
                                                                    <i class="fa fa-star active"></i>
                                                                    <i class="fa fa-star active"></i>
                                                                </div>
                                                            </div>
                                                        </th>
                                                        <td>
                                                            <a href="#">@i.Product.Name</a>
                                                        </td>
                                                        <td>
                                                            <span class="amount">@i.Product.Price.ToString("N0")
                                                                <span>تومان</span>
                                                            </span>
                                                        </td>
                                                        <td class="text-left actions">
                                                            <a href="#" class="remove-product">
                                                                <i
                                                                    class="mdi mdi-close"></i></a>
                                                        </td>
                                                    </tr>
                                                    <tr class="spacer"></tr>
                                                }
                                            }
                                            else
                                            {
                                                <tr class="spacer">
                                                    <span> محصولی ثبت نشده</span>
                                                </tr>
                                            }
                                        }

                                        </tbody>
                                    </table>
                                    @{
                                        if (productFavs.Any())
                                        {
                                            foreach (var i in productFavs)
                                            {
                                                <div class="profile-recent-fav">
                                                    <a href="#" class="img-profile-favorites">
                                                        <img src="~/image/Prods/@i.Product.ImageUrl">
                                                    </a>
                                                    <div class="profile-recent-fav-col">
                                                        <a href="#">@i.Product.Name</a>
                                                    </div>
                                                    <div class="profile-recent-fav-price">
                                                        <span class="amount">@i.Product.Price.ToString("N0")
                                                            <span>تومان</span>
                                                        </span>
                                                    </div>
                                                    <div class="profile-recent-fav-remove">
                                                        <a href="#"><i class="mdi mdi-close"></i></a>
                                                    </div>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="profile-recent-fav">
                                                
                                                <div class="profile-recent-fav-col">
                                                    <a href="#">محصولی ثبت نشده</a>
                                                </div>
                                            </div>
                                        }
                                    }
                                    
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>




             